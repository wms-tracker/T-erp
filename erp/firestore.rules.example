// ===================================================================
// ตัวอย่าง Firestore Security Rules — คัดลอกไปวางที่ Firebase Console
// (Firestore Database -> Rules) แล้วปรับแก้ตามความเหมาะสมก่อน Publish
// ===================================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- ฟังก์ชันช่วยตรวจสอบสิทธิ์ -----
    function isSignedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isActive() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }
    function hasRole(role) {
      return isSignedIn() && isActive() && myRole() == role;
    }
    function isAdmin() { return hasRole('admin'); }

    // ----- users: อ่าน-เขียนได้เฉพาะแอดมิน, ผู้ใช้อ่านข้อมูลตัวเองได้ -----
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // ----- orders: sales สร้าง/แก้ของตัวเอง, admin/warehouse แก้สถานะคลัง-จัดส่งได้, accounting อ่านอย่างเดียว -----
    match /orders/{orderId} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('sales') || isAdmin();
      allow update: if isAdmin()
                    || (hasRole('sales') && resource.data.createdBy == request.auth.uid)
                    || hasRole('warehouse'); // จำกัดเฉพาะฟิลด์ status/shipping ผ่าน validation เพิ่มเติมได้
      allow delete: if isAdmin();
    }

    // ----- counters: ตัวนับเลขเอกสารกลาง (orderCounter, pgCounter, invoiceCounter ...) -----
    match /counters/{id} {
      allow read, write: if isSignedIn() && isActive();
    }

    // ----- manifests: กำกับสินค้า (Manifest/Wave) -----
    match /manifests/{id} {
      allow read: if isSignedIn() && isActive();
      allow create, update: if hasRole('warehouse') || isAdmin();
      allow delete: if isAdmin();
    }

    // ----- pickingStrategies: กลยุทธ์จัดกลุ่ม -----
    match /pickingStrategies/{id} {
      allow read: if isSignedIn() && isActive();
      allow write: if hasRole('warehouse') || isAdmin();
    }

    // ----- pickingGroups: กลุ่มงานหยิบสินค้า (PG-YYYYMMDD-XXX) -----
    match /pickingGroups/{id} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('warehouse') || isAdmin();
      allow update: if hasRole('warehouse') || isAdmin();
      allow delete: if isAdmin();
    }

    // ----- verificationLogs: บันทึกการสแกน QC ทุก event -----
    match /verificationLogs/{id} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('warehouse') || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ----- purchaseOrders: ใบสั่งซื้อ (PO) -----
    match /purchaseOrders/{id} {
      allow read: if isSignedIn() && isActive();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ----- payments: รายการรับ-จ่ายเงิน — บัญชี/แอดมินบันทึกและแก้ไขได้ -----
    match /payments/{id} {
      allow read: if isSignedIn() && isActive();
      allow create, update: if hasRole('accounting') || isAdmin();
      allow delete: if isAdmin();
    }

    // ----- salesDocuments: ประวัติเอกสารขาย/ขนส่งที่จัดทำ (ใบส่งของ/ใบแพ็ค/ใบปะหน้าพัสดุ) -----
    match /salesDocuments/{id} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('admin') || hasRole('sales') || hasRole('warehouse');
      allow update, delete: if isAdmin();
    }

    // ----- routingBatches: ประวัติการจัดรูทขนส่ง/ปิดรอบคัตออฟ -----
    match /routingBatches/{id} {
      allow read: if isSignedIn() && isActive();
      allow create, update: if hasRole('admin') || hasRole('warehouse');
      allow delete: if isAdmin();
    }

    // ----- products / stockMovements: คลัง/แอดมินจัดการได้เต็มสิทธิ์ -----
    // sales อนุญาตให้ "update" ได้ด้วย (เพื่อจองสต๊อก/ปรับ reservedQty ตอนสร้างออเดอร์)
    // แต่สร้าง/ลบสินค้าได้เฉพาะคลังและแอดมินเท่านั้น
    match /products/{sku} {
      allow read: if isSignedIn() && isActive();
      allow create, delete: if hasRole('warehouse') || isAdmin();
      allow update: if hasRole('warehouse') || hasRole('sales') || isAdmin();
    }
    match /stockMovements/{id} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('warehouse') || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ----- invoices: เขียนได้เฉพาะบัญชีและแอดมิน -----
    match /invoices/{id} {
      allow read: if isSignedIn() && isActive();
      allow write: if hasRole('accounting') || isAdmin();
    }

    // ----- auditLog: ทุกคนเขียน (บันทึกอัตโนมัติ), อ่านได้เฉพาะแอดมิน/ผู้บริหาร -----
    match /auditLog/{id} {
      allow create: if isSignedIn() && isActive();
      allow read: if isAdmin() || hasRole('manager');
      allow update, delete: if false;
    }

    // ----- settings: การตั้งค่าระบบ (importConfig ฯลฯ) -----
    match /settings/{id} {
      allow read: if isSignedIn() && isActive();
      allow write: if hasRole('warehouse') || isAdmin();
    }

    // ----- importHistory: ประวัติการ Import จาก Google Sheets -----
    match /importHistory/{id} {
      allow read: if isSignedIn() && isActive();
      allow create: if hasRole('warehouse') || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
